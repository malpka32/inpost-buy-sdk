### InPost Buy SDK – optional configuration
###
### Copy to ".env" if you need local configuration (e.g. for manual API testing).

# Stage (sandbox) – OAuth2 client credentials
INPOST_BUY_STAGE_ENABLED=true
INPOST_BUY_STAGE_CLIENT_ID=
INPOST_BUY_STAGE_CLIENT_SECRET=
INPOST_BUY_STAGE_ORGANIZATION_ID=
